{
  "name": "billing-interface",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "prepare": "svelte-kit sync || echo ''",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "db:seed": "node scripts/seed/",
    "db:push:prod": "pnpm drizzle-kit push",
    "db:pull:prod": "pnpm drizzle-kit pull",
    "db:gene:prod": "pnpm drizzle-kit generate",
    "db:migr:prod": "pnpm drizzle-kit migrate",
    "db:push": "pnpm drizzle-kit push --config=drizzle-dev.config.ts",
    "db:pull": "pnpm drizzle-kit pull --config=drizzle-dev.config.ts",
    "db:gene": "pnpm drizzle-kit generate --config=drizzle-dev.config.ts",
    "db:migr": "pnpm drizzle-kit migrate --config=drizzle-dev.config.ts",
    "generate:seed:schema": "typescript-json-schema ./scripts/seed/seed.config.schema.ts SeedConfigSchema --out ./scripts/seed/seed.config.schema.json --required"
  },
  "devDependencies": {
    "@sveltejs/adapter-auto": "^7.0.1",
    "@sveltejs/kit": "^2.57.1",
    "@sveltejs/vite-plugin-svelte": "^7.0.0",
    "@types/lodash.debounce": "^4.0.9",
    "@types/node": "^25.6.0",
    "@types/pg": "^8.20.0",
    "drizzle-kit": "^0.31.10",
    "svelte": "^5.55.4",
    "svelte-check": "^4.4.6",
    "typescript": "^6.0.3",
    "typescript-json-schema": "^0.67.1",
    "vite": "^8.0.9"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "esbuild"
    ]
  },
  "dependencies": {
    "@lucide/svelte": "^1.8.0",
    "bcryptjs": "^3.0.3",
    "dayjs": "^1.11.20",
    "drizzle-orm": "^0.45.2",
    "extend-arabic-query": "^0.3.2",
    "jose": "^6.2.2",
    "lodash.debounce": "^4.0.8",
    "pg": "^8.20.0",
    "svelte-sonner": "^1.1.0"
  },
  "packageManager": "pnpm@10.33.0"
}